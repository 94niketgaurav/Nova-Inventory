# Database — each part independently overridable
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nova_inventory
DB_USER=postgres
DB_PASSWORD=postgres

# Redis / Cache
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300
ENABLE_CACHE=true           # Set to false to bypass Redis and go straight to DB

# Auth (disabled by default)
REQUIRE_AUTH=false
API_KEYS=

# Rate limiting
RATE_LIMIT_STOCK_READ=100/minute
RATE_LIMIT_DEFAULT=200/minute

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
LOW_STOCK_DEFAULT_THRESHOLD=10
