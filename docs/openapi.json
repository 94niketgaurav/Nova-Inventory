  "components": {
    "schemas": {
      "AnalyticsSummary": {
        "properties": {
          "stock": {
            "$ref": "#/components/schemas/StockAnalytics"
          },
          "orders": {
            "$ref": "#/components/schemas/OrderAnalytics"
          },
          "movements": {
            "$ref": "#/components/schemas/MovementAnalytics"
          }
        },
        "type": "object",
        "required": [
          "stock",
          "orders",
          "movements"
        ],
        "title": "AnalyticsSummary"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ItemCreate": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "price": {
            "anyOf": [
              {
                "type": "number",
                "exclusiveMinimum": 0.0
              },
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d{0,2}0*$"
              }
            ],
            "title": "Price"
          },
          "stock_quantity": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Stock Quantity"
          },
          "low_stock_threshold": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Low Stock Threshold",
            "default": 10
          }
        },
        "type": "object",
        "required": [
          "name",
          "price",
          "stock_quantity"
        ],
        "title": "ItemCreate",
        "example": {
          "description": "200g beef patty with lettuce and tomato",
          "low_stock_threshold": 10,
          "name": "Classic Burger",
          "price": "12.99",
          "stock_quantity": 50
        }
      },
      "ItemResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "price": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Price"
          },
          "stock_quantity": {
            "type": "integer",
            "title": "Stock Quantity"
          },
          "low_stock_threshold": {
            "type": "integer",
            "title": "Low Stock Threshold"
          },
          "is_low_stock": {
            "type": "boolean",
            "title": "Is Low Stock"
          },
          "version": {
            "type": "integer",
            "title": "Version"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "price",
          "stock_quantity",
          "low_stock_threshold",
          "is_low_stock",
          "version",
          "created_at",
          "updated_at"
        ],
        "title": "ItemResponse"
      },
      "ItemStockAdjust": {
        "properties": {
          "delta": {
            "type": "integer",
            "title": "Delta",
            "description": "Positive to add, negative to remove"
          },
          "reason": {
            "type": "string",
            "maxLength": 500,
            "minLength": 1,
            "title": "Reason"
          }
        },
        "type": "object",
        "required": [
          "delta",
          "reason"
        ],
        "title": "ItemStockAdjust",
        "example": {
          "delta": -5,
          "reason": "Damaged goods removed from stock"
        }
      },
      "LowStockAlert": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "stock_quantity": {
            "type": "integer",
            "title": "Stock Quantity"
          },
          "low_stock_threshold": {
            "type": "integer",
            "title": "Low Stock Threshold"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "stock_quantity",
          "low_stock_threshold"
        ],
        "title": "LowStockAlert"
      },
      "MovementAnalytics": {
        "properties": {
          "total_deductions": {
            "type": "integer",
            "title": "Total Deductions"
          },
          "total_restorations": {
            "type": "integer",
            "title": "Total Restorations"
          },
          "total_adjustments": {
            "type": "integer",
            "title": "Total Adjustments"
          },
          "net_stock_change": {
            "type": "integer",
            "title": "Net Stock Change"
          }
        },
        "type": "object",
        "required": [
          "total_deductions",
          "total_restorations",
          "total_adjustments",
          "net_stock_change"
        ],
        "title": "MovementAnalytics"
      },
      "MovementType": {
        "type": "string",
        "enum": [
          "DEDUCTION",
          "RESTORATION",
          "ADJUSTMENT"
        ],
        "title": "MovementType"
      },
      "OrderAnalytics": {
        "properties": {
          "total_orders": {
            "type": "integer",
            "title": "Total Orders"
          },
          "pending": {
            "type": "integer",
            "title": "Pending"
          },
          "confirmed": {
            "type": "integer",
            "title": "Confirmed"
          },
          "shipped": {
            "type": "integer",
            "title": "Shipped"
          },
          "delivered": {
            "type": "integer",
            "title": "Delivered"
          },
          "cancelled": {
            "type": "integer",
            "title": "Cancelled"
          },
          "rejected": {
            "type": "integer",
            "title": "Rejected"
          },
          "revenue": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Revenue"
          },
          "refund_value": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Refund Value"
          }
        },
        "type": "object",
        "required": [
          "total_orders",
          "pending",
          "confirmed",
          "shipped",
          "delivered",
          "cancelled",
          "rejected",
          "revenue",
          "refund_value"
        ],
        "title": "OrderAnalytics"
      },
      "OrderCreate": {
        "properties": {
          "item_id": {
            "type": "string",
            "format": "uuid",
            "title": "Item Id"
          },
          "quantity": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Quantity"
          },
          "customer_ref": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 255
              },
              {
                "type": "null"
              }
            ],
            "title": "Customer Ref"
          }
        },
        "type": "object",
        "required": [
          "item_id",
